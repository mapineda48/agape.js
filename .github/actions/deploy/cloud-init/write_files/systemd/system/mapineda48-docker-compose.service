[Unit]
Description=Docker Compose Service for mapineda48
Requires=docker.service mapineda48-blobfuse2-deploy.service
After=docker.service mapineda48-blobfuse2-deploy.service
# Asegura que los mounts existan antes
RequiresMountsFor=/mnt/deploy/vm/agape.js/docker/certs /mnt/deploy/vm/agape.js/docker/acme

[Service]
Type=oneshot
WorkingDirectory=/etc/agape.js
ExecStart=/usr/bin/docker compose up -d
ExecStop=/usr/bin/docker compose down
RemainAfterExit=true

[Install]
WantedBy=multi-user.target