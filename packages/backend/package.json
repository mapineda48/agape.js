{
  "name": "@mapineda48/agape.js",
  "version": "0.1.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/mapineda48/agape.js.git",
    "directory": "packages/backend"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "scripts": {
    "dev": "tsx watch --ignore '../frontend/node_modules/**' --tsconfig ./tsconfig.json bin/index.ts",
    "build": "rimraf dist && tsc -p ./tsconfig.json && tsc-alias -p ./tsconfig.json --resolve-full-paths -r ./lib/build/preserve-shared-imports.js && tsx bin/build.ts",
    "tsc": "tsc -p ./tsconfig.json --noEmit true --incremental true",
    "drizzle:push": "drizzle-kit push",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@mapineda48/agape": "workspace:*",
    "@azure/storage-blob": "^12.30.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "bcrypt": "^6.0.0",
    "chalk": "^5.6.2",
    "compression": "^1.8.1",
    "drizzle-orm": "^0.44.7",
    "express": "^5.2.1",
    "formidable": "^3.5.4",
    "jose": "^6.1.3",
    "morgan": "^1.10.1",
    "pg": "^8.17.2",
    "redis": "^5.10.0",
    "resend": "^6.8.0",
    "ms": "^2.1.3",
    "socket.io": "^4.8.3",
    "source-map": "^0.7.6",
    "stacktrace-parser": "^0.1.11",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.6",
    "@types/formidable": "^3.4.6",
    "@types/morgan": "^1.9.10",
    "@types/pg": "^8.16.0",
    "@types/ms": "^2.1.0",
    "drizzle-kit": "^0.31.8",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "vite": "^7.2.4",
    "vitest": "^4.0.18"
  }
}
