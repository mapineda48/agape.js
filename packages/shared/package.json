{
  "name": "@mapineda48/agape",
  "version": "0.1.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/mapineda48/agape.js.git",
    "directory": "packages/shared"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted",
    "exports": {
      ".": "./dist/index.js",
      "./*": "./dist/*.js"
    }
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "default": "./*.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "tsc": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@mapineda48/agape-rpc": "workspace:*"
  }
}
