{
  "name": "@mapineda48/agape-core",
  "version": "0.5.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/mapineda48/agape.js.git",
    "directory": "packages/core"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted",
    "exports": {
      ".": "./dist/index.js",
      "./*": "./dist/*.js"
    }
  },
  "exports": {
    "./*": {
      "types": "./dist/*.d.ts",
      "default": "./*.ts"
    }
  },
  "scripts": {
    "build": "tsc"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "typescript": "~5.9.3"
  },
  "dependencies": {
    "@mapineda48/agape-rpc": "workspace:*"
  }
}
