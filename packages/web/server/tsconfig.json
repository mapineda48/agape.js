{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "declaration": true,
    "sourceMap": false,
    "outDir": "../dist/server",
    "rootDir": ".",
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "rewriteRelativeImportExtensions": true,
    "types": ["node"],
    "lib": ["ESNext"]
  },
  "include": ["index.ts", "ssr.ts"],
  "exclude": ["postbuild.ts"]
}
