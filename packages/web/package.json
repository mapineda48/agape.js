{
  "name": "@mapineda48/agape-web",
  "version": "0.3.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/mapineda48/agape.js.git",
    "directory": "packages/web"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
