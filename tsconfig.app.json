{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "es2024",
    "module": "ESNext",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "sourceMap": false,
    "resolveJsonModule": true,
    "types": ["node"],
    "lib": ["ESNext"],
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "rewriteRelativeImportExtensions": true,
    "incremental": false,
    "noEmit": false,
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "#models/*": ["models/*"],
      "#lib/*": ["lib/*"],
      "#svc/*": ["services/*"],
      "#shared/*": ["shared/*"]
    }
  },
  "include": ["bin", "services", "shared", "lib", "models"],
  "exclude": ["dist", "web"]
}
