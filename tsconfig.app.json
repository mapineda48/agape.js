{
  "compilerOptions": {
    "target": "ES2024",
    "lib": ["ESNext"],
    "module": "ESNext",
    "moduleResolution": "node",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "incremental": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "#models/*": ["models/*"],
      "#lib/*": ["lib/*"],
      "#svc/*": ["services/*"],
      "#shared/*": ["shared/*"]
    }
  },
  "include": ["bin", "server.ts", "services", "shared", "lib", "models"],
  "exclude": ["node_modules", "dist", "web", "app", ".next"]
}
