{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@agape/*": [
        "./agape/*"
      ],
      "@client/*": [
        "./client/*"
      ]
    }
  },
  "include": [
    ".next/types/**/*.ts",
    "app/**/*.ts",
    "app/**/*.tsx",
    "next-env.d.ts", 
    "client/**/*.ts",
    "client/**/*.tsx",
  ],
  "exclude": [
    "node_modules"
  ],
  
  "ts-node": {
    
    "compilerOptions": {
      "lib": [
        "dom",
        "dom.iterable",
        "esnext"
      ],
      "allowJs": true,
      "skipLibCheck": true,
      "esModuleInterop": true,
      "allowSyntheticDefaultImports": true,
      "strict": true,
      "forceConsistentCasingInFileNames": true,
      "noFallthroughCasesInSwitch": true,
      "target": "ES2020",
      "module": "CommonJS",
      "outDir": "./dist/server",
      "noEmit": false,
      "declaration": false,
      "importHelpers": true,
      "moduleResolution": "node",
      "resolveJsonModule": true,
      "isolatedModules": true
    }
  }
}
