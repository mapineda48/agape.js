{
  "name": "agape.js",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev:app": "pnpm -C packages/backend dev",
    "dev:web": "pnpm -C packages/frontend dev",
    "build": "pnpm -C packages/shared build && pnpm -C packages/rpc build && pnpm -C packages/frontend build && pnpm -C packages/backend build",
    "tsc": "pnpm -r tsc",
    "test": "pnpm -r test:run",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "eslint": "^9.39.1",
    "fs-extra": "^11.3.3",
    "@types/fs-extra": "^11.0.4",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "pathe": "^2.0.3",
    "rimraf": "^6.1.3",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "typescript-eslint": "^8.46.4"
  }
}
