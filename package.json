{
  "name": "msgpack-vite-agape-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "lint": "eslint .",
    "preview": "vite preview",
    "watch": "tsx watch --tsconfig ./tsconfig.build.json",
    "prebuild": "rimraf dist && drizzle-kit generate && tsc -p ./tsconfig.build.json && vite build && rimraf dist/www/tsconfig.build.tsbuildinfo",
    "build": "tsx bin/build.ts",
    "postbuild": "rimraf dist/tsconfig.build.tsbuildinfo",
    "generate": "pnpm drizzle-kit generate",
    "drizzle-kit-push": "nodemon",
    "backend": "tsx watch --tsconfig ./tsconfig.build.json bin/index.ts",
    "frontend": "vite"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@heroicons/react": "^2.2.0",
    "@tailwindcss/vite": "^4.1.8",
    "@types/bcrypt": "^5.0.2",
    "@types/cls-hooked": "^4.3.9",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/formidable": "^3.4.5",
    "@types/fs-extra": "^11.0.4",
    "@types/glob": "^8.1.0",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/lodash": "^4.17.17",
    "@types/morgan": "^1.9.10",
    "@types/ms": "^2.1.0",
    "@types/node": "^22.15.30",
    "@types/pg": "^8.15.4",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "clsx": "^2.1.1",
    "drizzle-kit": "^0.31.1",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "framer-motion": "^12.16.0",
    "globals": "^16.0.0",
    "history": "^5.3.0",
    "lodash": "^4.17.21",
    "lucide-react": "^0.513.0",
    "mitt": "^3.0.1",
    "nodemon": "^3.1.10",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "rimraf": "^6.0.1",
    "tailwindcss": "^4.1.8",
    "tsx": "^4.19.4",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^6.3.5"
  },
  "dependencies": {
    "@azure/storage-blob": "^12.27.0",
    "@msgpack/msgpack": "^3.1.2",
    "bcrypt": "^6.0.0",
    "chalk": "^5.4.1",
    "cls-hooked": "^4.2.2",
    "compression": "^1.8.0",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "decimal.js": "^10.5.0",
    "drizzle-orm": "^0.43.1",
    "express": "^5.1.0",
    "formidable": "^3.5.4",
    "fs-extra": "^11.3.0",
    "glob": "^11.0.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "ms": "^2.1.3",
    "pg": "^8.16.0",
    "source-map": "^0.7.4"
  },
  "imports": {
    "#utils/*": "./lib/utils/*.ts",
    "#lib/*": "./lib/*.ts",
    "#svc/*": "./svc/*.ts",
    "#models/*": "./models/*.ts",
    "#session": "./lib/access/session.ts",
    "#logger": "./lib/log/logger.ts"
  }
