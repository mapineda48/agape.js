{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "types": ["vitest", "node"],
    // Vitest necesita resolver tests correctamente
    "noEmit": true
  },
  "include": [
    "tests/**/*.ts",
    "tests/**/*.tsx",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx"
  ]
}
